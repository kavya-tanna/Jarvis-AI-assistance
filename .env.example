# ===================================================
# JARVIS AI Assistant — Environment Variables
# ===================================================
# Copy this file to .env and fill in your API keys.
# Only GEMINI_API_KEY is required. All others optional.
# ===================================================

# --- Required ---
GEMINI_API_KEY=paste_your_gemini_api_key_here

# --- Optional AI Providers (enable fallback chain) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
DEEPSEEK_API_KEY=

# --- Voice (ElevenLabs for premium voice) ---
ELEVENLABS_API_KEY=
RESEMBLE_API_KEY=

# --- Weather ---
OPENWEATHER_API_KEY=

# --- Local AI (Ollama) ---
AI_MODE=cloud
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
